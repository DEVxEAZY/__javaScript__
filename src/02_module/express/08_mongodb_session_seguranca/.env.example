# ============================================================
# .env.example  —  copie para .env e preencha
# ============================================================
#
# Aula 138/139: o curso mostra subir um Mongo local. O caminho
# moderno e Atlas (gratis) + Compass (cliente desktop pra
# inspecionar collections). A connection string muda apenas
# o host/credenciais — o resto do codigo fica igual.
#
# Local (mongod rodando na sua maquina):
#   MONGO_URI=mongodb://127.0.0.1:27017/aulas
#
# Atlas (cluster gratis):
#   MONGO_URI=mongodb+srv://USUARIO:SENHA@cluster0.xxxxx.mongodb.net/aulas
#
# IMPORTANTE: nunca comite o .env. Esse arquivo .env.example
# vai pro git como template; o .env de verdade fica no .gitignore.
# ============================================================

MONGO_URI=mongodb://127.0.0.1:27017/aulas

# Segredo da sessao — em prod, gere algo como `openssl rand -hex 32`.
SESSION_SECRET=troque-este-segredo-em-producao

PORTA=3000
